# OpenLnk environment variables
# Copy to .env and fill in values. Never commit .env itself.

# Database (Supabase Mumbai — ADR-007)
DATABASE_URL=postgresql+asyncpg://openlnk_app:dev_password@localhost:5432/openlnk_dev

# Redis — two instances (eng review A1)
REDIS_JOBS_URL=redis://localhost:6379/0
REDIS_EXTRACTION_URL=redis://localhost:6380/0

# Auth
MSG91_AUTH_KEY=
JWT_SECRET=dev-secret-change-in-prod
JWT_ALGORITHM=HS256

# Extraction timeouts (eng review A4 / tension resolution)
EXTRACTION_TIMEOUT_TEXT_SECS=60
EXTRACTION_TIMEOUT_MEDIA_SECS=120

# LLM provider (TODOS T-001: DPDP review pending)
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
